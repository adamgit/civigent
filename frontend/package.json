{
  "name": "@ks/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "guard:api-boundary": "node ./scripts/guard-no-direct-api-fetch.mjs",
    "test": "npm run guard:api-boundary && vitest run",
    "test:watch": "vitest",
    "test:ws:single-tab": "vitest run src/__tests__/DocumentViewPage.test.tsx src/__tests__/DocsBrowserPage.tree-contract.test.tsx",
    "test:ws:shared-session": "vitest run src/__tests__/ws-client.test.ts src/__tests__/shared-websocket-transport.test.ts src/__tests__/AppLayout.shared-session.test.tsx"
  },
  "dependencies": {
    "@ks/milkdown-serializer": "file:../sharedlibs/milkdown-serializer",
    "@milkdown/crepe": "^7.18.0",
    "@tailwindcss/vite": "^4.2.0",
    "diff": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.6.2",
    "typescript": "^5.9.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
