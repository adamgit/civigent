# Port the web UI is served on (host-facing port)
PORT=8080

# KS_EXTERNAL_PORT is set automatically in compose.yaml from PORT above.
# It tells the backend which port users actually connect on (for startup messages
# and OAuth URL auto-detection). You should NOT need to set this manually.
# KS_EXTERNAL_PORT=8080

# UID/GID for file ownership (default: 1000, the first non-root user on most systems)
UID=1000
GID=1000

# Import existing markdown on first startup (when wiki-data/content is empty)
# IMPORT_CONTENT_FROM=/path/to/your/markdown

# Snapshot cache: set to a host path to browse rendered docs from your host
# (e.g. mount in Obsidian). Leave commented to use a Docker-managed volume.
# SNAPSHOT_DIR=./snapshot

# Set to false to disable snapshot generation entirely
SNAPSHOT_ENABLED=true

# Optional: force single-user mode (no external auth provider/account setup)
# Leave commented for default auth-provider mode.
# KS_AUTH_MODE=single_user
# KS_USER_NAME=Local User
# KS_USER_EMAIL=local-user@ks.local
# KS_USER_ID=human-ui

# SSO / OIDC login (see docs/sso-setup.md for provider-specific instructions)
# KS_AUTH_MODE=oidc
# KS_OIDC_PUBLIC_URL=https://your-civigent-domain
# KS_OIDC_ISSUER=https://accounts.google.com
# KS_OIDC_CLIENT_ID=your-client-id
# KS_OIDC_CLIENT_SECRET=your-client-secret
# KS_OIDC_DISPLAY_NAME=Sign in with Google

# Governance mode: "available" (toggle in UI) or "forced" (always governance view)
# KS_GOVERNANCE_MODE=available
